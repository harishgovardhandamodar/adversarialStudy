   "source": [
    "# Data Fingerprinting and Similarity Detection Analysis\n",
    "\n",
    "This notebook analyzes credit card transaction data to identify patterns and similarities using data fingerprinting techniques."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "XJXJXJXJXJXJ"
   },
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "from sklearn.preprocessing import StandardScaler\n",
    "from sklearn.metrics.pairwise import cosine_similarity\n",
    "from sklearn.cluster import KMeans\n",
    "from sklearn.decomposition import PCA\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "plt.rcParams['figure.figsize'] = (12, 8)\n",
    "pd.set_option('display.max_columns', None)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "YJYJYJYJYJYJ"
   },
   "outputs": [],
   "source": [
    "# Load the dataset\n",
    "df = pd.read_csv('/Users/harishdamodar/Codebase/adversarialStudy/Data-fingerprinting/credit_card_transactions.csv')\n",
    "\n",
    "# Display basic information about the dataset\n",
    "print(\"Dataset shape:\", df.shape)\n",
    "print(\"\\nDataset info:\")\n",
    "df.info()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "ZKZKZKZKZKZK"
   },
   "outputs": [],
   "source": [
    "# Display first few rows\n",
    "df.head(10)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "ALALALALALAL"
   },
   "outputs": [],
   "source": [
    "# Data cleaning and preprocessing\n",
    "# Remove unnecessary columns that don't contribute to fingerprinting\n",
    "df_clean = df.copy()\n",
    "\n",
    "# Convert date to datetime\n",
    "df_clean['trans_date_trans_time'] = pd.to_datetime(df_clean['trans_date_trans_time'])\n",
    "\n",
    "# Extract time features\n",
    "df_clean['hour'] = df_clean['trans_date_trans_time'].dt.hour\n",
    "df_clean['day_of_week'] = df_clean['trans_date_trans_time'].dt.dayofweek\n",
    "df_clean['month'] = df_clean['trans_date_trans_time'].dt.month\n",
    "\n",
    "# Handle categorical features\n",
    "categorical_features = ['gender', 'category']\n",
    "for col in categorical_features:\n",
    "    if col in df_clean.columns:\n",
    "        df_clean[col] = pd.Categorical(df_clean[col]).codes\n",
    "\n",
    "# Create a subset for fingerprinting analysis\n",
    "fingerprint_features = ['amt', 'hour', 'day_of_week', 'category', 'gender', 'city_pop']\n",
    "\n",
    "# Create the fingerprinting dataset\n",
    "df_fingerprint = df_clean[fingerprint_features].copy()\n",
    "df_fingerprint.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "BMBMBMBMBMBM"
   },
   "outputs": [],
   "source": [
    "# Data analysis\n",
    "print(\"Dataset statistics:\")\n",
    "df_fingerprint.describe()"
   ]
  },
  {
   "cell_type": "code",
