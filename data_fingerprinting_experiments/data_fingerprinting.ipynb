    "id": "DQDQDQDQDQDQ"
   },
   "outputs": [],
   "source": [
    "# Visualize transaction amount distribution\n",
    "plt.figure(figsize=(12, 6))\n",
    "plt.subplot(1, 2, 1)\n",
    "plt.hist(df_fingerprint['amt'], bins=50, alpha=0.7)\n",
    "plt.xlabel('Transaction Amount')\n",
    "plt.ylabel('Frequency')\n",
    "plt.title('Distribution of Transaction Amounts')\n",
    "\n",
    "plt.subplot(1, 2, 2)\n",
    "df_fingerprint['amt'].plot(kind='box')\n",
    "plt.ylabel('Transaction Amount')\n",
    "plt.title('Box Plot of Transaction Amounts')\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "EGEGEGEGEGEG"
   },
   "outputs": [],
   "source": [
    "# Data fingerprinting using PCA\n",
    "# Scale the features\n",
    "scaler = StandardScaler()\n",
    "scaled_data = scaler.fit_transform(df_fingerprint)\n",
    "\n",
    "# Apply PCA\n",
    "pca = PCA()\n",
    "pca_result = pca.fit_transform(scaled_data)\n",
    "\n",
    "# Explained variance\n",
    "plt.figure(figsize=(10, 6))\n",
    "plt.plot(range(1, len(pca.explained_variance_ratio_) + 1), np.cumsum(pca.explained_variance_ratio_))\n",
    "plt.xlabel('Number of Components')\n",
    "plt.ylabel('Cumulative Explained Variance')\n",
    "plt.title('Explained Variance by Principal Components')\n",
    "plt.grid(True)\n",
    "plt.show()\n",
    "\n",
    "print(\"Explained variance ratio:\")\n",
    "for i, ratio in enumerate(pca.explained_variance_ratio_):\n",
    "    print(f\"Component {i+1}: {ratio:.4f} ({np.sum(pca.explained_variance_ratio_[:i+1]):.4f} total)\")"
   ]
  },
   {
    "cell_type": "code",
    "execution_count": null,
    "metadata": {
     "id": "FJFJFJFJFJFJ"
    },
    "outputs": [],
    "source": [
     "# Create similarity matrix using cosine similarity (memory-efficient approach)\n",
     "# Limit dataset size to avoid memory issues\n",
     "max_samples = 1000  # Limit to 1000 samples to avoid memory issues\n",
     "if len(scaled_data) > max_samples:\n",
     "    # Sample data to reduce memory load\n",
     "    sample_indices = np.random.choice(len(scaled_data), max_samples, replace=False)\n",
     "    sample_data = scaled_data[sample_indices]\n",
     "    print(f\"Reducing data from {len(scaled_data)} to {max_samples} samples for similarity matrix computation\")\n",
     "else:\n",
     "    sample_data = scaled_data\n",
     "\n",
     "# Compute cosine similarity for sampled data\n",
     "similarity_matrix = cosine_similarity(sample_data)\n",
     "\n",
     "# Visualize similarity matrix for the sampled subset\n",
     "plt.figure(figsize=(10, 8))\n",
     "plt.imshow(similarity_matrix, cmap='coolwarm', aspect='auto')\n",
     "plt.colorbar(label='Cosine Similarity')\n",
     "plt.title('Cosine Similarity Matrix (Sampled Data)')\n",
     "plt.xlabel('Transaction Index')\n",
     "plt.ylabel('Transaction Index')\n",
     "plt.show()"
    ]
   },
    "outputs": [],
    "source": [
     "# Create similarity matrix using cosine similarity (efficient approach)\n",
     "# Instead of full matrix, compute similarity for a sample subset\n",
     "sample_size = min(1000, len(scaled_data))  # Limit to 1000 samples to avoid memory issues\n",
     "sample_indices = np.random.choice(len(scaled_data), sample_size, replace=False)\n",
     "sample_data = scaled_data[sample_indices]\n",
     "\n",
     "# Compute cosine similarity for sampled data\n",
     "similarity_matrix = cosine_similarity(sample_data)\n",
     "\n",
     "# Visualize similarity matrix for the sampled subset\n",
     "plt.figure(figsize=(10, 8))\n",
     "plt.imshow(similarity_matrix, cmap='coolwarm', aspect='auto')\n",
     "plt.colorbar(label='Cosine Similarity')\n",
     "plt.title('Cosine Similarity Matrix (Sampled Data)')\n",
     "plt.xlabel('Transaction Index')\n",
     "plt.ylabel('Transaction Index')\n",
     "plt.show()"
    ]
   },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "GKGKGKGKGKGK"
   },
   "outputs": [],
   "source": [
    "# Cluster transactions to detect similarities\n",
    "# Use KMeans clustering with 4 clusters\n",
    "kmeans = KMeans(n_clusters=4, random_state=42)\n",
    "clusters = kmeans.fit_predict(scaled_data)\n",
    "\n",
    "# Add cluster labels to dataframe\n",
    "df_clean['cluster'] = clusters\n",
    "\n",
    "# Analyze clusters\n",
    "cluster_analysis = df_clean.groupby('cluster').agg({\n",
    "    'amt': ['mean', 'std', 'count'],\n",
    "    'hour': 'mean',\n",
    "    'category': lambda x: x.mode().iloc[0] if not x.mode().empty else 'N/A'\n",
    "}).round(2)\n",
    "\n",
    "cluster_analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "id": "HSHSHSHSHSHS"
   },
   "outputs": [],
   "source": [
    "# Visualize clusters in 2D space using PCA\n",
    "pca_2d = PCA(n_components=2)\n",
    "pca_2d_result = pca_2d.fit_transform(scaled_data)\n",
    "\n",
    "plt.figure(figsize=(10, 8))\n",
    "scatter = plt.scatter(pca_2d_result[:, 0], pca_2d_result[:, 1], c=clusters, cmap='viridis', alpha=0.6)\n",
    "plt.xlabel(f'First Principal Component (Explains {pca_2d.explained_variance_ratio_[0]:.2%} variance)')\n",
    "plt.ylabel(f'Second Principal Component (Explains {pca_2d.explained_variance_ratio_[1]:.2%} variance)')\n",
    "plt.title('Transaction Clusters (2D PCA Projection)')\n",
    "plt.colorbar(scatter)\n",
    "plt.show()"
   ]
